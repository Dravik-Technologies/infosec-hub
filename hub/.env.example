# Copy this file to .env and fill in values
PORT=3010
NODE_ENV=development

# PostgreSQL / Prisma
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/securityapp

# Session secret — use a long random string in production
SESSION_SECRET=hub-dev-secret-change-me

# SSO token TTL in seconds (default 60)
SSO_TOKEN_TTL=60

# Microsoft Entra ID (Phase 1 via HUB)
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_AUTHORITY_HOST=https://login.microsoftonline.com
ENTRA_REDIRECT_URI=http://localhost:3010/auth/entra/callback
ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:3010/login
