# Copy this file to .env and fill in values
PORT=3010
NODE_ENV=development

# MongoDB — must match scorva-v1 database so users are shared
MONGODB_URI=mongodb://127.0.0.1:27017/scorva

# Session secret — use a long random string in production
SESSION_SECRET=hub-dev-secret-change-me

# SSO token TTL in seconds (default 60)
SSO_TOKEN_TTL=60
