# ─────────────────────────────────────────────────────────────────────────────
# CRATER — Environment Variables
# Copy this to .env:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (matches docker-compose.yml hard-coded values) ──────────────────
POSTGRES_DB=crater
POSTGRES_USER=crater
POSTGRES_PASSWORD=craterpassword

# DATABASE_URL for local tools (Prisma Studio, migrations from host machine).
# Inside Docker containers this is automatically overridden to use host "db".
DATABASE_URL=postgresql://crater:craterpassword@localhost:5433/crater

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:5174

# ─── Host Ports ───────────────────────────────────────────────────────────────
# Container ports stay fixed:
#   frontend 5173, backend 3000, postgres 5432, ollama 11434.
# These values control only the host ports published by Docker.
CRATER_FRONTEND_PORT=5174
CRATER_BACKEND_PORT=3002
CRATER_DB_PORT=5433
CRATER_PROD_FRONTEND_PORT=8080

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_TYPE=local
UPLOAD_DIR=./uploads

# ─── Local AI ─────────────────────────────────────────────────────────────────
# Crater's Docker stack runs Ollama as a container named "ollama".
# If you run the backend directly on your workstation instead of Docker, set this
# to http://localhost:11434.
OLLAMA_BASE_URL=http://ollama:11434
LOCAL_AI_MODEL=llama3.2:3b
LOCAL_AI_PROVIDER=ollama
LOCAL_AI_MAX_TOKENS=384
LOCAL_AI_CONTEXT_WINDOW=4096
LOCAL_AI_MAX_RAG_CHUNKS=3
LOCAL_AI_MAX_RAG_CHARS_PER_CHUNK=1200
