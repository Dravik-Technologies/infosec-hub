generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PRACTITIONER
  SYSTEM_OWNER
  AO
  SCA
}

enum ImpactLevel {
  LOW
  MODERATE
  HIGH
}

enum ProjectStatus {
  ACTIVE
  AUTHORIZED
  IATO
  EXPIRED
  ARCHIVED
}

enum StepStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETE
}

enum ControlStatus {
  PLANNED
  IMPLEMENTED
  INHERITED
  NOT_APPLICABLE
}

enum DiagramType {
  AUTHORIZATION_BOUNDARY
  NETWORK_TOPOLOGY
  DATA_FLOW
  RACK_ELEVATION
  TEMPEST
  SYSTEM_ARCHITECTURE
  INTERCONNECTION
  OTHER
}

enum Severity {
  CRITICAL
  HIGH
  MODERATE
  LOW
  INFORMATIONAL
}

enum POAMStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  RISK_ACCEPTED
  FALSE_POSITIVE
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role     @default(PRACTITIONER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships ProjectMember[]
  evidence    Evidence[]
  auditLogs   AuditLog[]
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id                String        @id @default(cuid())
  name              String
  systemDescription String?
  impactLevel       ImpactLevel   @default(LOW)
  authBoundary      String?
  status            ProjectStatus @default(ACTIVE)
  atoExpiresAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  members          ProjectMember[]
  rmfSteps         RMFStep[]
  controlInstances ControlInstance[]
  diagrams         Diagram[]
  poamItems        POAMItem[]
  auditLogs        AuditLog[]
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      Role

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ─── RMF Steps (0–6 per project) ─────────────────────────────────────────────

model RMFStep {
  id          String     @id @default(cuid())
  projectId   String
  stepNumber  Int
  status      StepStatus @default(NOT_STARTED)
  data        Json?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, stepNumber])
}

// ─── 800-53 Control Library (seeded, read-only) ───────────────────────────────

model Control {
  id          String  @id @default(cuid())
  controlId   String  @unique
  family      String
  title       String
  description String
  guidance    String?
  lowBaseline  Boolean @default(false)
  modBaseline  Boolean @default(false)
  highBaseline Boolean @default(false)

  instances ControlInstance[]
}

// ─── Per-project control tailoring ───────────────────────────────────────────

model ControlInstance {
  id                     String        @id @default(cuid())
  projectId              String
  controlId              String
  status                 ControlStatus @default(PLANNED)
  implementationStatement String?
  tailoringJustification  String?
  inheritedFrom          String?
  responsible            String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  project  Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  control  Control    @relation(fields: [controlId], references: [id])
  evidence Evidence[]

  @@unique([projectId, controlId])
}

// ─── Evidence ─────────────────────────────────────────────────────────────────

model Evidence {
  id                String   @id @default(cuid())
  controlInstanceId String
  uploadedById      String
  fileName          String
  fileKey           String
  mimeType          String
  fileSize          Int
  description       String?
  createdAt         DateTime @default(now())

  controlInstance ControlInstance @relation(fields: [controlInstanceId], references: [id], onDelete: Cascade)
  uploadedBy      User            @relation(fields: [uploadedById], references: [id])
}

// ─── Diagrams ─────────────────────────────────────────────────────────────────

model Diagram {
  id          String      @id @default(cuid())
  projectId   String
  name        String
  type        DiagramType
  fileKey     String
  mimeType    String
  fileSize    Int
  version     Int         @default(1)
  stepNumber  Int?
  sspSection  String?
  annotations Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── POA&M ────────────────────────────────────────────────────────────────────

model POAMItem {
  id                  String     @id @default(cuid())
  projectId           String
  poamId              String
  weakness            String
  description         String
  severity            Severity
  status              POAMStatus @default(OPEN)
  scheduledCompletion DateTime?
  resources           String?
  milestones          Json?
  riskScore           Float?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, poamId])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  projectId  String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}
