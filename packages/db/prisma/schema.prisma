// Shared PostgreSQL schema for Security App Factory
// All mission-app models include siteId for multi-tenant isolation.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

enum ControlOwnershipMode {
  enterprise
  site
  hybrid
}

enum ControlOwnerType {
  enterprise
  site
}

// ─── Hub / SCORVA shared models ────────────────────────────────────────────────

model Tenant {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  controlModel ControlOwnershipMode @default(hybrid) @map("control_model")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  sites          Site[]
  controlCatalog ControlCatalog[]
  siteControls   SiteControlImplementation[]

  @@map("tenants")
}

model Site {
  id        String   @id
  tenantId  String?  @map("tenant_id")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users               User[]
  controls            Control[]
  tasks               Task[]
  poams               Poam[]
  atoPackages         AtoPackage[]
  conmons             ConMon[]
  workstations        Workstation[]
  yubiKeys            YubiKey[]
  licenses            License[]
  agreements          Agreement[]
  notifications       Notification[]
  trackers            Tracker[]
  projectSystems      ProjectSystem[]
  securityEvents      SecurityEvent[]
  evidenceArtifacts   EvidenceArtifact[]
  inspectionCampaigns InspectionCampaign[]
  mashFacilities      MashFacilitySecurity[]
  mashPersonnel       MashPersonnelSecurity[]
  mashActivities      MashActivitiesSecurity[]
  mashDocuments       MashDocumentControl[]
  mashDd254Registers  MashDd254Register[]
  mashMedia           MashMediaControl[]
  mashSelfInspections MashSelfInspectionOp[]
  mashFindings        MashSecurityFinding[]
  siteControlCatalogs ControlCatalog[]            @relation("SiteOwnedControlCatalog")
  siteControls        SiteControlImplementation[]

  @@index([tenantId])
  @@map("sites")
}

model User {
  id                String    @id
  name              String
  title             String?
  username          String    @unique
  email             String    @unique
  passwordHash      String    @map("password_hash")
  role              String    @default("Hub Viewer")
  siteId            String?   @map("site_id")
  site              Site?     @relation(fields: [siteId], references: [id])
  siteIds           String[]  @default([]) @map("site_ids")
  status            String    @default("Active")
  tokenEpoch        Int       @default(0) @map("token_epoch")
  yubikey           String?
  workstation       String?
  lastLogin         DateTime? @map("last_login")
  trainingCompliant Boolean   @default(false) @map("training_compliant")
  trainingDue       String?   @map("training_due")
  dod8140           Json?     @map("dod_8140")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([tokenEpoch])
  @@map("users")
}

model Control {
  id                     String   @id
  title                  String
  family                 String?
  status                 String   @default("Not Implemented")
  baseline               String?
  lastReview             String?  @map("last_review")
  findings               Int      @default(0)
  notes                  String?
  description            String?
  implementationGuidance String?  @map("implementation_guidance")
  siteId                 String   @map("site_id")
  site                   Site     @relation(fields: [siteId], references: [id])
  conmonStatus           String?  @map("conmon_status")
  conmonGroup            String?  @map("conmon_group")
  conmonFrequency        String?  @map("conmon_frequency")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("controls")
}

model ControlCatalog {
  id                    String           @id @default(cuid())
  tenantId              String?          @map("tenant_id")
  tenant                Tenant?          @relation(fields: [tenantId], references: [id])
  controlKey            String           @map("control_key")
  title                 String
  family                String?
  baseline              String?
  description           String?
  source                String?
  implementationDefault String?          @map("implementation_default")
  ownerType             ControlOwnerType @default(enterprise) @map("owner_type")
  ownerSiteId           String?          @map("owner_site_id")
  ownerSite             Site?            @relation("SiteOwnedControlCatalog", fields: [ownerSiteId], references: [id])
  isTemplate            Boolean          @default(true) @map("is_template")
  isActive              Boolean          @default(true) @map("is_active")
  version               String?
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  siteImplementations SiteControlImplementation[]

  @@index([tenantId])
  @@index([ownerType, ownerSiteId])
  @@unique([tenantId, ownerType, ownerSiteId, controlKey])
  @@map("control_catalog")
}

model SiteControlImplementation {
  id                     String         @id @default(cuid())
  tenantId               String?        @map("tenant_id")
  tenant                 Tenant?        @relation(fields: [tenantId], references: [id])
  siteId                 String         @map("site_id")
  site                   Site           @relation(fields: [siteId], references: [id])
  controlCatalogId       String         @map("control_catalog_id")
  controlCatalog         ControlCatalog @relation(fields: [controlCatalogId], references: [id])
  status                 String         @default("Not Implemented")
  lastReview             String?        @map("last_review")
  findings               Int            @default(0)
  notes                  String?
  implementationGuidance String?        @map("implementation_guidance")
  conmonStatus           String?        @map("conmon_status")
  conmonGroup            String?        @map("conmon_group")
  conmonFrequency        String?        @map("conmon_frequency")
  assignedTo             String?        @map("assigned_to")
  evidenceSummary        String?        @map("evidence_summary")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  findingsRecords   SiteControlFinding[]
  evidenceArtifacts SiteControlEvidence[]

  @@index([tenantId])
  @@index([siteId])
  @@index([controlCatalogId])
  @@unique([siteId, controlCatalogId])
  @@map("site_control_implementations")
}

model SiteControlFinding {
  id          String                    @id @default(cuid())
  siteControlId String                  @map("site_control_id")
  siteControl SiteControlImplementation @relation(fields: [siteControlId], references: [id], onDelete: Cascade)
  severity    String?
  title       String
  description String?
  status      String                    @default("Open")
  openedAt    DateTime                  @default(now()) @map("opened_at")
  closedAt    DateTime?                 @map("closed_at")
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  @@index([siteControlId])
  @@index([status])
  @@map("site_control_findings")
}

model SiteControlEvidence {
  id          String                    @id @default(cuid())
  siteControlId String                  @map("site_control_id")
  siteControl SiteControlImplementation @relation(fields: [siteControlId], references: [id], onDelete: Cascade)
  artifactType String?                  @map("artifact_type")
  fileName    String?                   @map("file_name")
  url         String?
  notes       String?
  uploadedBy  String?                   @map("uploaded_by")
  uploadedAt  DateTime                  @default(now()) @map("uploaded_at")

  @@index([siteControlId])
  @@map("site_control_evidence")
}

model Task {
  id             String   @id
  title          String
  siteId         String   @map("site_id")
  site           Site     @relation(fields: [siteId], references: [id])
  type           String?
  status         String   @default("Open")
  priority       String?
  assignee       String?
  dueDate        String?  @map("due_date")
  control        String?
  linkedControls String[] @default([]) @map("linked_controls")
  activityId     String?  @map("activity_id")
  evidence       String?
  created        String?
  createdBy      String?  @map("created_by")
  notes          String?
  source         String?
  sourceId       String?  @map("source_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("tasks")
}

model Poam {
  id                  String    @id
  title               String
  controlId           String?   @map("control_id")
  weakness            String?
  severity            String?
  status              String    @default("Open")
  siteId              String    @map("site_id")
  site                Site      @relation(fields: [siteId], references: [id])
  sourceType          String?   @map("source_type")
  sourceId            String?   @map("source_id")
  responsibleParty    String?   @map("responsible_party")
  pointOfContact      String?   @map("point_of_contact")
  resources           String?
  scheduledCompletion String?   @map("scheduled_completion")
  milestones          Json?     @default("[]")
  identifiedDate      String?   @map("identified_date")
  atoId               String?   @map("ato_id")
  poamType            String?   @map("poam_type")
  comments            String?
  completedDate       String?   @map("completed_date")
  closedDate          String?   @map("closed_date")
  riskDecision        String?   @map("risk_decision")
  riskRationale       String?   @map("risk_rationale")
  riskWorkflowState   String    @default("Draft") @map("risk_workflow_state")
  riskSubmittedAt     DateTime? @map("risk_submitted_at")
  riskSubmittedBy     String?   @map("risk_submitted_by")
  riskReviewedAt      DateTime? @map("risk_reviewed_at")
  riskReviewedBy      String?   @map("risk_reviewed_by")
  riskReviewNotes     String?   @map("risk_review_notes")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("poams")
}

model AtoPackage {
  id           String   @id
  system       String
  category     String
  status       String
  issued       String?
  expires      String?
  ao           String?
  controls     Int      @default(0)
  openFindings Int      @default(0) @map("open_findings")
  siteId       String   @map("site_id")
  site         Site     @relation(fields: [siteId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("ato_packages")
}

model ConMon {
  id                    String   @id @default(cuid())
  siteId                String   @map("site_id")
  site                  Site     @relation(fields: [siteId], references: [id])
  controlId             String   @map("control_id")
  controlTitle          String   @map("control_title")
  family                String
  status                String   @default("Pending")
  dueDate               String   @map("due_date")
  daagJsigFrequency     String?  @map("daag_jsig_frequency")
  baselineApplicability String?  @map("baseline_applicability")
  conmonGroup           String?  @map("conmon_group")
  assignee              String?
  reviewOutcome         String?  @map("review_outcome")
  notes                 String?
  completedDate         String?  @map("completed_date")
  linkedControls        String[] @default([]) @map("linked_controls")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([siteId, controlId])
  @@map("con_mon")
}

model Workstation {
  id             String   @id
  assetTag       String?  @map("asset_tag")
  hostname       String
  type           String   @default("Workstation")
  username       String?
  siteId         String?  @map("site_id")
  site           Site?    @relation(fields: [siteId], references: [id])
  os             String?
  ip             String?
  location       String?
  classification String   @default("Unclassified")
  status         String   @default("Available")
  system         String?
  keyExpiry      String?  @map("key_expiry")
  lastSeen       String?  @map("last_seen")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("workstations")
}

model YubiKey {
  id                String   @id
  serial            String   @unique
  model             String?
  status            String   @default("Unassigned")
  username          String?
  siteId            String?  @map("site_id")
  site              Site?    @relation(fields: [siteId], references: [id])
  issued            String?
  lastAuth          String?  @map("last_auth")
  lostDestroyedDate String?  @map("lost_destroyed_date")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("yubi_keys")
}

model License {
  id        String   @id
  product   String
  vendor    String?
  seats     Int      @default(0)
  used      Int      @default(0)
  status    String   @default("Active")
  siteId    String?  @map("site_id")
  site      Site?    @relation(fields: [siteId], references: [id])
  expires   String?
  cost      Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("licenses")
}

model Agreement {
  id         String   @id
  title      String
  category   String   @default("Agreement")
  type       String
  status     String   @default("Active")
  signed     String?
  expires    String?
  parties    String?
  assignedTo String?  @map("assigned_to")
  siteId     String   @map("site_id")
  site       Site     @relation(fields: [siteId], references: [id])
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("agreements")
}

model AuditLog {
  id        String   @id @default(cuid())
  username  String?
  action    String
  resource  String?
  detail    String?
  siteId    String   @map("site_id")
  timestamp DateTime @default(now())

  @@index([siteId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id
  type      String   @default("info")
  title     String
  message   String?
  siteId    String?  @map("site_id")
  site      Site?    @relation(fields: [siteId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([siteId])
  @@map("notifications")
}

model SecurityEvent {
  id          String   @id
  type        String   @default("Other")
  severity    String   @default("Medium")
  source      String?
  assetId     String?  @map("asset_id")
  description String?
  status      String   @default("New")
  siteId      String   @map("site_id")
  site        Site     @relation(fields: [siteId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("security_events")
}

model Tracker {
  id            String   @id @default(cuid())
  name          String
  description   String?
  category      String?
  frequency     String?
  owner         String?
  nextDue       String?  @map("next_due")
  lastCompleted String?  @map("last_completed")
  status        String   @default("Active")
  controlId     String?  @map("control_id")
  columns       Json?    @default("[]")
  rows          Json?    @default("[]")
  subtrackers   Json?    @default("[]")
  siteId        String?  @map("site_id")
  site          Site?    @relation(fields: [siteId], references: [id])
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("trackers")
}

model EvidenceArtifact {
  id           String   @id @default(cuid())
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  filename     String
  mimeType     String   @map("mime_type")
  size         Int
  artifactType String?  @map("artifact_type")
  notes        String?
  uploadedBy   String?  @map("uploaded_by")
  data         Bytes
  siteId       String?  @map("site_id")
  site         Site?    @relation(fields: [siteId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([resourceType, resourceId])
  @@index([siteId])
  @@map("evidence_artifacts")
}

model ChecklistTemplate {
  id          String             @id @default(cuid())
  name        String
  source      String?
  version     String?
  description String?
  isActive    Boolean            @default(true) @map("is_active")
  sections    ChecklistSection[]
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  @@map("checklist_templates")
}

model ChecklistSection {
  id          String            @id @default(cuid())
  templateId  String            @map("template_id")
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sectionCode String?           @map("section_code")
  title       String
  description String?
  sortOrder   Int               @default(0) @map("sort_order")
  items       ChecklistItem[]
  createdAt   DateTime          @default(now()) @map("created_at")

  @@index([templateId])
  @@map("checklist_sections")
}

model ChecklistItem {
  id                String           @id @default(cuid())
  sectionId         String           @map("section_id")
  section           ChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  itemCode          String?          @map("item_code")
  nispomRef         String?          @map("nispom_ref")
  questionText      String           @map("question_text")
  applicabilityNote String?          @map("applicability_note")
  riskCategory      String?          @map("risk_category")
  evidenceRequired  Boolean          @default(false) @map("evidence_required")
  controlRef        String?          @map("control_ref")
  sortOrder         Int              @default(0) @map("sort_order")
  createdAt         DateTime         @default(now()) @map("created_at")

  @@index([sectionId])
  @@map("checklist_items")
}

// ─── Inspection Campaign models ───────────────────────────────────────────────

model InspectionCampaign {
  id              String                      @id @default(cuid())
  siteId          String                      @map("site_id")
  site            Site                        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  templateId      String?                     @map("template_id")
  templateName    String                      @map("template_name")
  templateVersion String?                     @map("template_version")
  name            String
  inspectionType  String?                     @map("inspection_type")
  facilityArea    String?                     @map("facility_area")
  standard        String?
  overallRating   String?                     @map("overall_rating")
  status          String                      @default("Draft")
  startDate       DateTime?                   @map("start_date")
  targetDate      DateTime?                   @map("target_date")
  completedAt     DateTime?                   @map("completed_at")
  ownerName       String?                     @map("owner_name")
  leadInspector   String?                     @map("lead_inspector")
  notes           String?
  createdBy       String                      @map("created_by")
  sections        InspectionCampaignSection[]
  items           InspectionCampaignItem[]
  findings        InspectionFinding[]
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@index([siteId])
  @@index([status])
  @@map("inspection_campaigns")
}

model InspectionCampaignSection {
  id                String                   @id @default(cuid())
  campaignId        String                   @map("campaign_id")
  campaign          InspectionCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  templateSectionId String?                  @map("template_section_id")
  sectionCode       String?                  @map("section_code")
  title             String
  sortOrder         Int                      @default(0) @map("sort_order")
  status            String                   @default("Not Started")
  scorePercent      Int?                     @map("score_percent")
  summary           String?
  completedAt       DateTime?                @map("completed_at")
  items             InspectionCampaignItem[]
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  @@index([campaignId])
  @@map("inspection_campaign_sections")
}

model InspectionCampaignItem {
  id                String                    @id @default(cuid())
  campaignId        String                    @map("campaign_id")
  campaign          InspectionCampaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sectionId         String                    @map("section_id")
  section           InspectionCampaignSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  templateItemId    String?                   @map("template_item_id")
  itemCode          String?                   @map("item_code")
  requirementRef    String?                   @map("requirement_ref")
  nispomRef         String?                   @map("nispom_ref")
  questionText      String                    @map("question_text")
  applicabilityNote String?                   @map("applicability_note")
  riskCategory      String?                   @map("risk_category")
  evidenceRequired  Boolean                   @default(false) @map("evidence_required")
  controlRef        String?                   @map("control_ref")
  sortOrder         Int                       @default(0) @map("sort_order")
  result            String?
  severity          String?
  evidenceNotes     String?                   @map("evidence_notes")
  inspectorComment  String?                   @map("inspector_comment")
  status            String                    @default("Not Started")
  workNotes         String?                   @map("work_notes")
  updatedBy         String?                   @map("updated_by")
  statusUpdatedAt   DateTime?                 @map("status_updated_at")
  taskId            String?                   @map("task_id")
  poamId            String?                   @map("poam_id")
  findings          InspectionFinding[]
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  @@index([campaignId])
  @@index([sectionId])
  @@index([result])
  @@map("inspection_campaign_items")
}

model InspectionFinding {
  id                String                       @id @default(cuid())
  campaignId        String                       @map("campaign_id")
  campaign          InspectionCampaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  itemId            String                       @map("item_id")
  item              InspectionCampaignItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  findingNumber     String?                      @map("finding_number")
  title             String
  description       String
  requirementRef    String?                      @map("requirement_ref")
  severity          String                       @default("Medium")
  status            String                       @default("Open")
  responsibleOrg    String?                      @map("responsible_org")
  responsibleUser   String?                      @map("responsible_user")
  dueDate           DateTime?                    @map("due_date")
  closedDate        DateTime?                    @map("closed_date")
  rootCause         String?                      @map("root_cause")
  evidence          Json?                        @default("[]")
  notes             String?
  correctiveActions InspectionCorrectiveAction[]
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")

  @@index([campaignId])
  @@index([itemId])
  @@index([status])
  @@index([severity])
  @@map("inspection_findings")
}

model InspectionCorrectiveAction {
  id                String              @id @default(cuid())
  findingId         String              @map("finding_id")
  finding           InspectionFinding   @relation(fields: [findingId], references: [id], onDelete: Cascade)
  actionText        String              @map("action_text")
  status            String              @default("Open")
  assignedTo        String?             @map("assigned_to")
  assignedOrg       String?             @map("assigned_org")
  targetDate        DateTime?           @map("target_date")
  completedDate     DateTime?           @map("completed_date")
  verificationBy    String?             @map("verification_by")
  verificationNotes String?             @map("verification_notes")
  closureEvidence   Json?               @default("[]") @map("closure_evidence")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([findingId])
  @@index([status])
  @@index([targetDate])
  @@map("inspection_corrective_actions")
}

// ─── MASH models ───────────────────────────────────────────────────────────────

model MashSite {
  id             String  @id @default(cuid())
  siteId         String  @unique @map("site_id")
  name           String
  location       String?
  status         String  @default("Active")
  scifZones      Int?    @map("scif_zones")
  nextInspection String? @map("next_inspection")

  employees     Employee[]
  inspections   InspectionItem[]
  contracts     Contract[]
  mashDocuments MashDocument[]

  @@map("mash_sites")
}

model Employee {
  id                 String   @id @default(cuid())
  name               String
  mashSiteId         String   @map("mash_site_id")
  mashSite           MashSite @relation(fields: [mashSiteId], references: [siteId])
  position           String?
  clearanceLevel     String   @map("clearance_level")
  clearanceGranted   String?  @map("clearance_granted")
  reinvestigationDue String?  @map("reinvestigation_due")
  trainingDueDate    String?  @map("training_due_date")
