// Shared PostgreSQL schema for Security App Factory
// All mission-app models include siteId for multi-tenant isolation.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

// ─── Hub / SCORVA shared models ────────────────────────────────────────────────

model Site {
  id        String   @id
  label     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  controls        Control[]
  tasks           Task[]
  poams           Poam[]
  atoPackages     AtoPackage[]
  conmons         ConMon[]
  workstations    Workstation[]
  yubiKeys        YubiKey[]
  licenses        License[]
  agreements      Agreement[]
  notifications   Notification[]
  trackers        Tracker[]
  projectSystems  ProjectSystem[]
  securityEvents  SecurityEvent[]

  @@map("sites")
}

model User {
  id               String    @id
  name             String
  title            String?
  username         String    @unique
  email            String    @unique
  passwordHash     String    @map("password_hash")
  role             String    @default("Viewer")
  siteId           String?   @map("site_id")
  site             Site?     @relation(fields: [siteId], references: [id])
  siteIds          String[]  @default([]) @map("site_ids")
  status           String    @default("Active")
  yubikey          String?
  workstation      String?
  lastLogin        DateTime? @map("last_login")
  trainingCompliant Boolean  @default(false) @map("training_compliant")
  trainingDue      String?   @map("training_due")
  dod8140          Json?     @map("dod_8140")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Control {
  id                    String   @id
  title                 String
  family                String?
  status                String   @default("Not Implemented")
  baseline              String?
  lastReview            String?  @map("last_review")
  findings              Int      @default(0)
  notes                 String?
  description           String?
  implementationGuidance String? @map("implementation_guidance")
  siteId                String   @map("site_id")
  site                  Site     @relation(fields: [siteId], references: [id])
  conmonStatus          String?  @map("conmon_status")
  conmonGroup           String?  @map("conmon_group")
  conmonFrequency       String?  @map("conmon_frequency")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("controls")
}

model Task {
  id             String   @id
  title          String
  siteId         String   @map("site_id")
  site           Site     @relation(fields: [siteId], references: [id])
  type           String?
  status         String   @default("Open")
  priority       String?
  assignee       String?
  dueDate        String?  @map("due_date")
  control        String?
  linkedControls String[] @default([]) @map("linked_controls")
  activityId     String?  @map("activity_id")
  evidence       String?
  created        String?
  createdBy      String?  @map("created_by")
  notes          String?
  source         String?
  sourceId       String?  @map("source_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("tasks")
}

model Poam {
  id                  String   @id
  title               String
  controlId           String?  @map("control_id")
  weakness            String?
  severity            String?
  status              String   @default("Open")
  siteId              String   @map("site_id")
  site                Site     @relation(fields: [siteId], references: [id])
  sourceType          String?  @map("source_type")
  sourceId            String?  @map("source_id")
  responsibleParty    String?  @map("responsible_party")
  pointOfContact      String?  @map("point_of_contact")
  resources           String?
  scheduledCompletion String?  @map("scheduled_completion")
  milestones          Json?    @default("[]")
  identifiedDate      String?  @map("identified_date")
  atoId               String?  @map("ato_id")
  poamType            String?  @map("poam_type")
  comments            String?
  completedDate       String?  @map("completed_date")
  closedDate          String?  @map("closed_date")
  riskDecision        String?  @map("risk_decision")
  riskRationale       String?  @map("risk_rationale")
  riskWorkflowState   String   @default("Draft") @map("risk_workflow_state")
  riskSubmittedAt     DateTime? @map("risk_submitted_at")
  riskSubmittedBy     String?  @map("risk_submitted_by")
  riskReviewedAt      DateTime? @map("risk_reviewed_at")
  riskReviewedBy      String?  @map("risk_reviewed_by")
  riskReviewNotes     String?  @map("risk_review_notes")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("poams")
}

model AtoPackage {
  id           String   @id
  system       String
  category     String
  status       String
  issued       String?
  expires      String?
  ao           String?
  controls     Int      @default(0)
  openFindings Int      @default(0) @map("open_findings")
  siteId       String   @map("site_id")
  site         Site     @relation(fields: [siteId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("ato_packages")
}

model ConMon {
  id                    String   @id @default(cuid())
  siteId                String   @map("site_id")
  site                  Site     @relation(fields: [siteId], references: [id])
  controlId             String   @map("control_id")
  controlTitle          String   @map("control_title")
  family                String
  status                String   @default("Pending")
  dueDate               String   @map("due_date")
  daagJsigFrequency     String?  @map("daag_jsig_frequency")
  baselineApplicability String?  @map("baseline_applicability")
  conmonGroup           String?  @map("conmon_group")
  assignee              String?
  reviewOutcome         String?  @map("review_outcome")
  notes                 String?
  completedDate         String?  @map("completed_date")
  linkedControls        String[] @default([]) @map("linked_controls")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([siteId, controlId])
  @@map("con_mon")
}

model Workstation {
  id             String   @id
  assetTag       String?  @map("asset_tag")
  hostname       String
  type           String   @default("Workstation")
  username       String?
  siteId         String?  @map("site_id")
  site           Site?    @relation(fields: [siteId], references: [id])
  os             String?
  ip             String?
  location       String?
  classification String   @default("Unclassified")
  status         String   @default("Available")
  system         String?
  keyExpiry      String?  @map("key_expiry")
  lastSeen       String?  @map("last_seen")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("workstations")
}

model YubiKey {
  id        String   @id
  serial    String   @unique
  model     String?
  status    String   @default("Unassigned")
  username  String?
  siteId    String?  @map("site_id")
  site      Site?    @relation(fields: [siteId], references: [id])
  issued    String?
  lastAuth  String?  @map("last_auth")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("yubi_keys")
}

model License {
  id        String   @id
  product   String
  vendor    String?
  seats     Int      @default(0)
  used      Int      @default(0)
  status    String   @default("Active")
  siteId    String?  @map("site_id")
  site      Site?    @relation(fields: [siteId], references: [id])
  expires   String?
  cost      Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("licenses")
}

model Agreement {
  id         String   @id
  title      String
  category   String   @default("Agreement")
  type       String
  status     String   @default("Active")
  signed     String?
  expires    String?
  parties    String?
  assignedTo String?  @map("assigned_to")
  siteId     String   @map("site_id")
  site       Site     @relation(fields: [siteId], references: [id])
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("agreements")
}

model AuditLog {
  id        String   @id @default(cuid())
  username  String?
  action    String
  resource  String?
  detail    String?
  siteId    String   @map("site_id")
  timestamp DateTime @default(now())

  @@map("audit_logs")
}

model Notification {
  id        String   @id
  type      String   @default("info")
  title     String
  message   String?
  siteId    String?  @map("site_id")
  site      Site?    @relation(fields: [siteId], references: [id])
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model SecurityEvent {
  id          String   @id
  type        String   @default("Other")
  severity    String   @default("Medium")
  source      String?
  assetId     String?  @map("asset_id")
  description String?
  status      String   @default("New")
  siteId      String   @map("site_id")
  site        Site     @relation(fields: [siteId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("security_events")
}

model Tracker {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  frequency   String?
  owner       String?
  nextDue     String?  @map("next_due")
  lastCompleted String? @map("last_completed")
  status      String   @default("Active")
  controlId   String?  @map("control_id")
  columns     Json?    @default("[]")
  rows        Json?    @default("[]")
  subtrackers Json?    @default("[]")
  siteId      String?  @map("site_id")
  site        Site?    @relation(fields: [siteId], references: [id])
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("trackers")
}

// ─── MASH models ───────────────────────────────────────────────────────────────

model MashSite {
  id             String   @id @default(cuid())
  siteId         String   @unique @map("site_id")
  name           String
  location       String?
  status         String   @default("Active")
  scifZones      Int?     @map("scif_zones")
  nextInspection String?  @map("next_inspection")

  employees      Employee[]
  inspections    InspectionItem[]
  contracts      Contract[]
  mashDocuments  MashDocument[]

  @@map("mash_sites")
}

model Employee {
  id                 String    @id @default(cuid())
  name               String
  mashSiteId         String    @map("mash_site_id")
  mashSite           MashSite  @relation(fields: [mashSiteId], references: [siteId])
  position           String?
  clearanceLevel     String    @map("clearance_level")
  clearanceGranted   String?   @map("clearance_granted")
  reinvestigationDue String?   @map("reinvestigation_due")
  trainingDueDate    String?   @map("training_due_date")
  annualBriefingDue  String?   @map("annual_briefing_due")
  status             String    @default("active")
  notes              String?

  @@map("employees")
}

model InspectionItem {
  id          String   @id @default(cuid())
  mashSiteId  String   @map("mash_site_id")
  mashSite    MashSite @relation(fields: [mashSiteId], references: [siteId])
  controlId   String?  @map("control_id")
  description String?
  status      String   @default("Pending")
  notes       String?

  @@map("inspections")
}

model Contract {
  id           String    @id @default(cuid())
  contractId   String    @map("contract_id")
  mashSiteId   String    @map("mash_site_id")
  mashSite     MashSite  @relation(fields: [mashSiteId], references: [siteId])
  vendor       String?
  scope        String?
  totalValue   Float     @default(0) @map("total_value")
  amountSpent  Float     @default(0) @map("amount_spent")
  expiration   String?
  status       String    @default("Active")
  transactions Transaction[]

  @@map("contracts")
}

model MashDocument {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("other")
  mashSiteId  String   @map("mash_site_id")
  mashSite    MashSite @relation(fields: [mashSiteId], references: [siteId])
  status      String   @default("draft")
  version     String   @default("v1.0")
  fileRef     String?  @map("file_ref")
  submittedBy String?  @map("submitted_by")
  reviewedBy  String?  @map("reviewed_by")
  approvedBy  String?  @map("approved_by")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("mash_documents")
}

model Transaction {
  id            String   @id @default(cuid())
  transactionId String?  @map("transaction_id")
  contractId    String   @map("contract_id")
  contract      Contract @relation(fields: [contractId], references: [id])
  mashSiteId    String   @map("mash_site_id")
  amount        Float    @default(0)
  type          String   @default("Expense")
  date          DateTime @default(now())

  @@map("transactions")
}

// ─── CRATER models (RMF Automation Engine) ─────────────────────────────────────

model ProjectSystem {
  id                    String         @id @default(cuid())
  externalId            String?        @unique @map("external_id")
  name                  String
  abbreviation          String
  systemType            String         @default("Major Application") @map("system_type")
  organization          String
  description           String?
  classificationMarking String?        @map("classification_marking")
  systemOwner           String?        @map("system_owner")
  isso                  String?
  issm                  String?
  confidentiality       String         @default("Low")
  integrity             String         @default("Low")
  availability          String         @default("Low")
  baseline              String         @default("LOW")
  atoStatus             String         @default("Pre-ATO") @map("ato_status")
  siteId                String         @map("site_id")
  site                  Site           @relation(fields: [siteId], references: [id])
  controls              ProjectControl[]
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  @@map("project_systems")
}

model ProjectControl {
  id                      String        @id @default(cuid())
  projectSystemId         String        @map("project_system_id")
  projectSystem           ProjectSystem @relation(fields: [projectSystemId], references: [id], onDelete: Cascade)
  controlId               String        @map("control_id")
  controlTitle            String        @map("control_title")
  family                  String
  status                  String        @default("Not Implemented")
  implementationStatement String?       @map("implementation_statement")
  standardText            String?       @map("standard_text")
  autoFilled              Boolean       @default(false) @map("auto_filled")
  tailoringRequired       Boolean       @default(false) @map("tailoring_required")
  implementationOrigin    String        @default("System Specific") @map("implementation_origin")
  evidenceLinks           String[]      @default([]) @map("evidence_links")
  assessorNotes           String?       @map("assessor_notes")
  validatedAt             DateTime?     @map("validated_at")
  validatedBy             String?       @map("validated_by")
  siteId                  String        @map("site_id")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")

  @@unique([projectSystemId, controlId])
  @@map("project_controls")
}

model StandardLibrary {
  id                      String   @id @default(cuid())
  controlId               String   @unique @map("control_id")
  controlTitle            String   @map("control_title")
  family                  String
  implementationStatement String   @map("implementation_statement")
  implementationOrigin    String   @default("System Specific") @map("implementation_origin")
  tailoringRequired       Boolean  @default(false) @map("tailoring_required")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("standard_library")
}

// ─── LAVA models ───────────────────────────────────────────────────────────────

model LavaSaar {
  id                      String    @id @default(cuid())
  // Personal
  lastName                String    @map("last_name")
  firstName               String    @map("first_name")
  middleInitial           String?   @map("middle_initial")
  rankGrade               String?   @map("rank_grade")
  organization            String
  officeSymbol            String?   @map("office_symbol")
  phone                   String?
  email                   String
  supervisorName          String?   @map("supervisor_name")
  supervisorPhone         String?   @map("supervisor_phone")
  supervisorEmail         String?   @map("supervisor_email")
  // System
  systemName              String    @map("system_name")
  systemOwner             String?   @map("system_owner")
  classification          String    @default("UNCLASSIFIED")
  purposeOfAccess         String?   @map("purpose_of_access")
  // Access
  accessType              String    @default("standard") @map("access_type")
  privilegedJustification String?   @map("privileged_justification")
  privilegedAccessType    String?   @map("privileged_access_type")
  // Training
  annualTrainingDate      DateTime? @map("annual_training_date")
  derivativeTrainingDate  DateTime? @map("derivative_training_date")
  // Workflow
  status                  String    @default("pending")
  rejectionReason         String?   @map("rejection_reason")
  // Hardware hand-off
  yubiKeySerial           String?   @map("yubi_key_serial")
  tokenType               String?   @map("token_type")
  // Agreement
  agreementSigned         Boolean   @default(false) @map("agreement_signed")
  agreementSignedAt       DateTime? @map("agreement_signed_at")
  // Audit
  submittedBy             String?   @map("submitted_by")
  reviewedBy              String?   @map("reviewed_by")
  provisionedBy           String?   @map("provisioned_by")
  siteId                  String?   @map("site_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@map("lava_saars")
}

model LavaSystemRequest {
  id             String      @id @default(cuid())
  systemName     String      @map("system_name")
  systemOwner    String      @map("system_owner")
  ownerEmail     String      @map("owner_email")
  ownerPhone     String?     @map("owner_phone")
  classification String      @default("UNCLASSIFIED")
  purpose        String
  networkType    String?     @map("network_type")
  status         String      @default("pending")
  siteId         String?     @map("site_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  assets         LavaAsset[]

  @@map("lava_system_requests")
}

model LavaAsset {
  id              String            @id @default(cuid())
  systemRequestId String            @map("system_request_id")
  systemRequest   LavaSystemRequest @relation(fields: [systemRequestId], references: [id], onDelete: Cascade)
  assetTag        String?           @map("asset_tag")
  serialNumber    String?           @map("serial_number")
  make            String?
  model           String?
  assetType       String?           @map("asset_type")
  classification  String            @default("UNCLASSIFIED")
  assignedUser    String?           @map("assigned_user")
  location        String?
  notes           String?
  siteId          String?           @map("site_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("lava_assets")
}

model MashCollection {
  name      String   @id
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mash_collections")
}

model DataFabricDocument {
  name      String   @id
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("data_fabric_documents")
}

model DataFabricSession {
  token     String   @id
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("data_fabric_sessions")
}
