<?xml version="1.0" encoding="UTF-8"?>
<!--
  SCORVA – Azure App Service web.config
  This config handles two jobs:
    1. Proxy /api/* and /auth/* to the Node.js Express server (iisnode)
    2. Serve static frontend assets (js, css, icons, fonts) directly via IIS
-->
<configuration>
  <system.webServer>

    <!-- ================================================
         iisnode — run Node.js via IIS
         Azure App Service installs iisnode automatically
         when the runtime stack is set to Node.js.
    ================================================ -->
    <handlers>
      <add name="iisnode" path="server/index.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- ================================================
         MIME types
    ================================================ -->
    <staticContent>
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
    </staticContent>

    <!-- ================================================
         Global security headers
    ================================================ -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="camera=(), microphone=(), geolocation=()" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" />
      </customHeaders>
    </httpProtocol>

    <!-- ================================================
         URL Rewrite rules
         Priority order (top wins):
           1. /api/*  and /auth/*  → Node.js via iisnode
           2. Static files exist   → serve directly
           3. Everything else      → Node.js (SPA + auth redirect)
    ================================================ -->
    <rewrite>
      <rules>

        <!-- Rule 1a: Route /api/* to Node.js -->
        <rule name="NodeJS API" stopProcessing="true">
          <match url="^api(/.*)?$" />
          <action type="Rewrite" url="server/index.js" />
        </rule>

        <!-- Rule 1b: Route /auth/* to Node.js -->
        <rule name="NodeJS Auth" stopProcessing="true">
          <match url="^auth(/.*)?$" />
          <action type="Rewrite" url="server/index.js" />
        </rule>

        <!-- Rule 2: Serve existing static files directly (React build in client/dist + fonts/icons) -->
        <rule name="Static Files" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Rule 3: Everything else goes to Node.js (handles SPA routing + login redirect) -->
        <rule name="NodeJS App" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server/index.js" />
        </rule>

      </rules>

      <!-- Cache-Control headers per file type via outbound rules -->
      <outboundRules>
        <!-- fonts — immutable, 1 year -->
        <rule name="Cache-fonts">
          <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/fonts/" />
          </conditions>
          <action type="Rewrite" value="public, max-age=31536000, immutable" />
        </rule>
        <!-- icons — immutable, 1 year -->
        <rule name="Cache-icons">
          <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/icons/" />
          </conditions>
          <action type="Rewrite" value="public, max-age=31536000, immutable" />
        </rule>
        <!-- JS — 1 hour -->
        <rule name="Cache-js">
          <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="\.js$" />
            <add input="{REQUEST_URI}" pattern="^/sw\.js$" negate="true" />
          </conditions>
          <action type="Rewrite" value="public, max-age=3600" />
        </rule>
        <!-- CSS — 1 hour -->
        <rule name="Cache-css">
          <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="\.css$" />
          </conditions>
          <action type="Rewrite" value="public, max-age=3600" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- ================================================
         iisnode configuration
    ================================================ -->
    <iisnode
      node_env="%node_env%"
      nodeProcessCommandLine="node"
      interceptErrorsFromNode="true"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

  </system.webServer>

  <!-- ================================================
       sw.js — no-cache + Service-Worker-Allowed header
  ================================================ -->
  <location path="sw.js">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Cache-Control" value="no-cache" />
          <add name="Service-Worker-Allowed" value="/" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>

</configuration>
