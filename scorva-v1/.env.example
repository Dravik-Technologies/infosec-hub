# ============================================================
# SCORVA – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Node environment: "development" or "production"
NODE_ENV=development

# Port the Express server listens on (Azure sets this automatically)
PORT=3000

# MongoDB Atlas connection string
# Local:   mongodb://localhost:27017/scorva
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Azure App Settings key: MONGODB_URI
MONGODB_URI=mongodb://localhost:27017/scorva

# Session secret — generate a strong random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string_at_least_48_chars
