# ============================================================
# SCORVA – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# Node environment: "development" or "production"
NODE_ENV=development

# Port the Express server listens on (Azure sets this automatically)
PORT=3000

# PostgreSQL / Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/securityapp

# Session secret — generate a strong random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string_at_least_48_chars

# JWT signing secret (used to sign/verify access tokens)
# If omitted, SCORVA falls back to SESSION_SECRET.
JWT_SECRET=replace_with_a_different_long_random_string

# JWT lifetime (e.g. 8h, 12h, 1d)
JWT_EXPIRES_IN=8h
